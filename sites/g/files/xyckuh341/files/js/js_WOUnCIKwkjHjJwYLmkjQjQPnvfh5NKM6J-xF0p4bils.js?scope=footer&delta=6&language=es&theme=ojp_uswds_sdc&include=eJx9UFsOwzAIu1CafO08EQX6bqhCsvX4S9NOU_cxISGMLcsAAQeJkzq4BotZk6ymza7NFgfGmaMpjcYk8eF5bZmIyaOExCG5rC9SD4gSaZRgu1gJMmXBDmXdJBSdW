(function($,Drupal){"use strict";Drupal.behaviors.ojpReturnToTop={attach:function(context,settings){$(window).scroll(function(){if($(this).scrollTop()>100)$("#return-to-top").removeClass("hide").addClass("show");else $("#return-to-top").removeClass("show").addClass("hide");});$("#return-to-top",context).on("click",function(event){event.preventDefault();$("html, body").animate({scrollTop:0},300);return false;});}};})(jQuery,Drupal);;
