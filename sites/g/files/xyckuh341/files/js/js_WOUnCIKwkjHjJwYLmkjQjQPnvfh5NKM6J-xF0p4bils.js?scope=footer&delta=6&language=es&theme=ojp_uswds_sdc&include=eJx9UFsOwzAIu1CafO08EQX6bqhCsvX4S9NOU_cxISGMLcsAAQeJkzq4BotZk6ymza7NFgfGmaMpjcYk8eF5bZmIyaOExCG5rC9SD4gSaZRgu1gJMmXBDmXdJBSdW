(function(Drupal,once){Drupal.behaviors.ojpNavActiveLinks={attach:function(context){once('ojp-nav-active','.usa-nav__primary',context).forEach(function(nav){var currentPath=window.location.pathname;nav.querySelectorAll('.usa-nav__link:not(.usa-accordion__button)').forEach(function(link){if(link.getAttribute('href')===currentPath){link.classList.add('usa-current');var span=link.querySelector('span');if(span)span.classList.add('usa-current-border');}});});}};})(Drupal,once);;
