(function($,Drupal){Drupal.behaviors.anchorAccordion={attach:function(){if(!document.querySelector(".usa-accordion"))return;const handleAccordionFromHash=()=>{const hash=window.location.hash;if(!hash)return;const targetId=hash.substring(1);const target=document.getElementById(targetId);if(!target)return;const button=document.querySelector(`button[aria-controls="${targetId}"]`);if(!button)return;const ancestorPairs=[];let parentContent=target.closest('.usa-accordion__content');while(parentContent){const parentId=parentContent.getAttribute('id');if(parentId){const parentBtn=document.querySelector(`button[aria-controls="${parentId}"]`);if(parentBtn)ancestorPairs.push({btn:parentBtn,content:parentContent});}parentContent=parentContent.parentElement?parentContent.parentElement.closest('.usa-accordion__content'):null;}const ancestorButtons=new Set(ancestorPairs.map((p)=>p.btn));document.querySelectorAll('.usa-accordion__button[aria-expanded="true"]').forEach((openButton)=>{if(openButton!==button&&!ancestorButtons.has(openButton))openButton.click();});[...ancestorPairs].reverse().forEach(({btn,content})=>{btn.setAttribute("aria-expanded","true");content.removeAttribute("hidden");});button.setAttribute("aria-expanded","true");target.removeAttribute("hidden");const targetOffset=$(button).offset().top;$("html, body").animate({scrollTop:targetOffset-90},1000);};setTimeout(handleAccordionFromHash,1000);window.addEventListener("hashchange",handleAccordionFromHash);document.querySelectorAll('a[href^="#"]:not([href="#"]), a[href*="#"]:not([href$="#"])').forEach((anchor)=>{anchor.addEventListener("click",handleAccordionFromHash);});}};})(jQuery,Drupal);;
